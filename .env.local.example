# Variables de entorno - EJEMPLO
# Copiar este archivo a .env.local y completar con tus valores

# ============================================
# MiniMax M3 (API compatible con Anthropic SDK)
# ============================================
# Obtener tu key en: https://platform.minimaxi.com/user-center/payment/token-plan
# OJO: la API va en api.minimax.io (NO api.minimaxi.com → da 401 con esta key).
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_API_KEY=

# ============================================
# NextAuth (auth con Google)
# ============================================
# Generar en: https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID → Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://tu-dominio.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret para NextAuth (cualquier string random largo)
AUTH_SECRET=

# ============================================
# Vercel KV (persistencia de proyectos)
# ============================================
# Crear en Vercel Dashboard → Storage → KV
# Las variables se generan automáticamente
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ============================================
# Vercel Blob (storage de imágenes - opcional)
# ============================================
BLOB_READ_WRITE_TOKEN=

# ============================================
# Resend (envío de PDFs por email - opcional)
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@soyleoai.com
