# Variables de entorno - EJEMPLO
# Copiar este archivo a .env.local y completar con tus valores

# ============================================
# MiniMax M3 (API compatible con Anthropic SDK)
# ============================================
# Obtener tu key en: https://platform.minimaxi.com/user-center/payment/token-plan
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=

# ============================================
# Vercel Blob (storage de imágenes)
# ============================================
# Crear en Vercel Dashboard → Storage → Blob
# El token se genera automáticamente al crear el Blob store
BLOB_READ_WRITE_TOKEN=

# ============================================
# Resend (envío de PDFs por email - opcional)
# ============================================
# Crear cuenta en: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@soyleoai.com

# ============================================
# Upstash Redis (rate limit - opcional)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
